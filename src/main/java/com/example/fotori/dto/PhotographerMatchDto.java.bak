package com.example.fotori.dto;

import lombok.Builder;
import lombok.Data;
import java.util.List;

@Data
@Builder
public class PhotographerMatchDto {
    // Thông tin photographer
    private Long photographerId;
    private String fullName;
    private String avatarUrl;
    private String city;
    private String bio;
    private Integer experienceYears;
    private Double averageRating;

    // Thông tin packages
    private Integer minPrice;           // Giá package thấp nhất
    private Integer maxPrice;           // Giá package cao nhất
    private List<String> conceptNames;  // Danh sách concepts

    // AI Match Score
    private Integer matchScore;         // 0-100
    private Integer conceptMatch;       // 0-100
    private Integer budgetMatch;        // 0-100
    private Integer locationMatch;      // 0-100
    private Integer ratingScore;        // 0-100
    private List<String> matchReasons;  // Lý do match
    private String matchLabel;          // "Rất phù hợp", "Phù hợp",...
    private Boolean isAvailable;        // Available vào ngày booking
}